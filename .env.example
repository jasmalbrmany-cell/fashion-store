# ============================================
# Fashion Hub Store - Environment Variables
# ============================================
# 
# IMPORTANT: Copy this file to .env and fill in your actual values
# Never commit .env file to git!

# Supabase Configuration
# Get these values from your Supabase project dashboard
# https://app.supabase.com/project/YOUR_PROJECT/settings/api

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: If using Supabase for storage
VITE_SUPABASE_STORAGE_URL=https://your-project-id.supabase.co/storage/v1/object/public

# Application Settings
VITE_APP_NAME=Fashion Hub
VITE_APP_URL=http://localhost:5173

# WhatsApp Settings (for checkout)
VITE_WHATSAPP_DEFAULT=967777123456

# Optional: Google Gemini API (for AI features)
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Firecrawl API (for product scraping)
FIRECRAWL_API_KEY=your-firecrawl-api-key-here
