# ============================================
# Fashion Hub Store - Environment Variables Template
# ============================================
# 
# 📋 انسخ هذا الملف إلى .env.local واملأ القيم الحقيقية
# 📋 Copy this file to .env.local and fill in your actual values
#
# ⚠️ لا ترفع ملف .env.local على Git أبداً!
# ⚠️ Never commit .env.local to Git!

# ──────────────────────────────────────────────
# Supabase Configuration (Required)
# Get values from: https://app.supabase.com/project/YOUR_PROJECT/settings/api
# ──────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ──────────────────────────────────────────────
# Application Settings
# ──────────────────────────────────────────────
VITE_APP_NAME=Fashion Hub
VITE_APP_URL=http://localhost:5173
VITE_WHATSAPP_DEFAULT=967777123456

# ──────────────────────────────────────────────
# Optional: Google Gemini API (for AI features)
# Get key from: https://aistudio.google.com/app/apikey
# ──────────────────────────────────────────────
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# ──────────────────────────────────────────────
# Optional: Firecrawl API (for product scraping)
# Server-side only - not exposed to browser
# Get key from: https://firecrawl.dev
# ──────────────────────────────────────────────
FIRECRAWL_API_KEY=your-firecrawl-api-key-here
